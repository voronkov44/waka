# postgres
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=postgresDB

# pgAdmin
PGADMIN_DEFAULT_EMAIL=test@test.com
PGADMIN_DEFAULT_PASSWORD=password

# minio (root creds)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=password

# s3 (MinIO) config for API
S3_ENDPOINT=http://minio:9000
S3_PRESIGN_ENDPOINT=http://localhost:19000
S3_ACCESS_KEY=${MINIO_ROOT_USER}
S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}
S3_BUCKET=waka
S3_PUBLIC_BASE_URL=http://localhost:19000

# future: private bucket mode (presigned GET links)
S3_USE_PRESIGNED=false
S3_PRESIGN_TTL=15m

# jwt
AUTH_JWT_SECRET=super-secret-change-me
AUTH_TOKEN_TTL=24h

# admin auth
AUTH_ADMIN_NAME=admin
AUTH_ADMIN_PASSWORD=super-secret-password
