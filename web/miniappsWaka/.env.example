# Optional: explicit API base URL for direct browser -> API calls.
# Leave empty to use same-origin paths (/api/*), recommended for ngrok + Vite proxy.
VITE_API_BASE_URL=

# Local backend target used by Vite dev proxy for /api/* requests.
VITE_API_PROXY_TARGET=http://localhost:28080

# Optional: comma-separated list of hostnames allowed by Vite dev server.
# Required when opening the dev server through a tunnel (ngrok, etc.).
# Example: VITE_DEV_ALLOWED_HOSTS=my-app.ngrok-free.app
VITE_DEV_ALLOWED_HOSTS=
